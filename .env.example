# Builder.io Public API Key (safe to expose in browser)
# Found at: builder.io → Space Settings → API Keys → Public Key
NEXT_PUBLIC_BUILDER_API_KEY=your_public_api_key_here

# Builder.io Private API Key (server-side only, never expose in browser)
# Found at: builder.io → Space Settings → API Keys → Private Key
# Required only for running scripts/setup-builder-models.mjs
BUILDER_PRIVATE_KEY=your_private_api_key_here
